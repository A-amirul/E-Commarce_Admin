@model IEnumerable<Ecommerce.Domain.Entities.Product>

<h2>Products</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Product</a>

<table class="table table-bordered">

    <tr>
        <th>Name</th>
        <th>Price</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>

            <td>@p.Name</td>
            <td>@p.Price</td>

        </tr>
    }

</table>